---

const { author, title, work, briefNote, imgUrl } = Astro.props;
---

<hr> 

<div class="author">
    <div class="author-image">
        <img src={ imgUrl } alt=`Photo of ${ author }` width=50%>
    </div>

    <div class="author-description">
        <h2>{ author }</h2>
        <h3>{ title }</h3>   

        <p>{ work }</p>
        <p> A note from { author }: <em>{ briefNote }</em> </p>
    </div>     

</div>

<style> 
    .author {
        display: flex;
    }

    h2, h3 {
        margin-bottom: 0.1rem;
        margin-top: 0.2rem;
    }

    img {
        border-radius: 0.5rem;
        width: 90%;
    }

    @media screen and (min-width: 636px) {
        .author {
            display: flex;
        }
    }
</style>

 